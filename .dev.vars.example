ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=replace-with-a-random-string-at-least-32-characters-long

# Shared with tv-proxy-go — encrypts playback URLs so upstream links are not visible in the browser.
# Generate: openssl rand -base64 48
PROXY_TOKEN_SECRET=replace-with-a-random-string-at-least-32-characters-long

# Public URL of your Go proxy (must match PROXY_BASE on the proxy server).
PROXY_BASE_URL=http://127.0.0.1:8080/proxy

# Optional override for channel data API. Defaults to PROXY_BASE_URL without /proxy.
# DATA_API_URL=http://127.0.0.1:8080

# Shared with tv-proxy-go for admin writes to /data/* endpoints.
# Generate: openssl rand -base64 48
DATA_API_SECRET=replace-with-a-random-string-at-least-32-characters-long

# Local setup:
# 1. cp .dev.vars.example .dev.vars
# 2. Set values above
# 3. Configure MongoDB + DATA_API_SECRET on Go proxy (.env)
# 4. Start Go proxy: cd ../tv-proxy-go && go run .
# 5. Start UI: npm run preview
